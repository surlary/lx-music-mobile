diff -urN -x '*.json' -x '*.md' -x .DS_Store -x '*.patch' -x .gradle lx-music-mobile-master/src/core/download.ts lx/src/core/download.ts
--- lx-music-mobile-master/src/core/download.ts	1970-01-01 08:00:00.000000000 +0800
+++ lx/src/core/download.ts	2026-03-16 16:10:59.000000000 +0800
@@ -0,0 +1,335 @@
+import { LIST_IDS } from '@/config/constant'
+import listAction from '@/store/list/action'
+import listState from '@/store/list/state'
+import { fixNewMusicInfoQuality } from '@/utils'
+import { saveListPrevSelectId } from '@/utils/data'
+import { downloadFile, stopDownload, temporaryDirectoryPath, privateStorageDirectoryPath, mkdir, existsFile } from '@/utils/fs'
+import { getMusicUrl } from './music'
+import { getDownloadPath } from '@/utils/downloadPath'
+
+// 下载任务状态枚举
+export type DownloadTaskStatus = 'waiting' | 'downloading' | 'paused' | 'completed' | 'error'
+
+// 下载任务接口
+interface DownloadTask {
+  id: string
+  musicInfo: LX.Music.MusicInfoOnline
+  status: DownloadTaskStatus
+  progress: number
+  speed: string
+  downloaded: number
+  total: number
+  filePath?: string
+  error?: string
+  jobId?: number // 下载任务ID
+}
+
+// 全局下载任务管理器
+class DownloadManager {
+  private tasks: Map<string, DownloadTask> = new Map()
+  private eventEmitter: {
+    on: (event: string, callback: any) => void
+    off: (event: string, callback: any) => void
+    emit: (event: string, ...args: any[]) => void
+  } = {
+    on: (event: string, callback: any) => {},
+    off: (event: string, callback: any) => {},
+    emit: (event: string, ...args: any[]) => {}
+  }
+  private activeDownloads = 0
+  private maxConcurrentDownloads = 3 // 最大并发下载数
+
+  // 添加下载任务
+  async addDownloadTask(musicInfo: LX.Music.MusicInfoOnline) {
+    const taskId = musicInfo.id
+    
+    // 检查任务是否已存在
+    if (this.tasks.has(taskId)) {
+      const task = this.tasks.get(taskId)!
+      if (task.status === 'completed') {
+        return // 已完成的任务不需要重新下载
+      }
+      // 如果是其他状态，更新任务信息
+      task.musicInfo = musicInfo
+      task.status = 'waiting'
+      task.progress = 0
+      task.downloaded = 0
+      task.total = 0
+      this.updateTask(task)
+      return
+    }
+
+    const task: DownloadTask = {
+      id: taskId,
+      musicInfo,
+      status: 'waiting',
+      progress: 0,
+      speed: '0 KB/s',
+      downloaded: 0,
+      total: 0,
+    }
+
+    this.tasks.set(taskId, task)
+    this.updateTask(task)
+    
+    // 如果有空闲的下载槽位，立即开始下载
+    if (this.activeDownloads < this.maxConcurrentDownloads) {
+      this.processNextTask()
+    }
+  }
+
+  // 处理下一个等待中的任务
+  private async processNextTask() {
+    if (this.activeDownloads >= this.maxConcurrentDownloads) {
+      return // 没有空闲的下载槽位
+    }
+
+    // 查找下一个等待中的任务
+    for (const task of this.tasks.values()) {
+      if (task.status === 'waiting') {
+        this.startDownload(task)
+        break
+      }
+    }
+  }
+
+  // 开始下载任务
+  private async startDownload(task: DownloadTask) {
+    if (task.status !== 'waiting') return
+
+    this.activeDownloads++
+    task.status = 'downloading'
+    this.updateTask(task)
+
+    try {
+      // 获取音乐URL
+      const musicUrl = await getMusicUrl({
+        musicInfo: task.musicInfo,
+        quality: '128k' as LX.Quality, // 默认质量
+        isRefresh: false,
+      })
+
+      if (!musicUrl) {
+        throw new Error('无法获取音乐下载链接')
+      }
+
+      // 构建文件路径
+      const fileName = this.generateFileName(task.musicInfo)
+      const downloadDir = await getDownloadPath()
+      const filePath = `${downloadDir}/${fileName}`
+      
+      // 确保下载目录存在
+      await this.ensureDownloadDirectoryExists(downloadDir)
+      
+      // 开始下载
+      const downloadResult = downloadFile(musicUrl, filePath, {
+        progress: (res: any) => {
+          const progress = Math.round((res.bytesWritten / res.contentLength) * 100)
+          const speed = this.formatBytes(res.bytesWritten / (res.time / 1000))
+          
+          task.progress = progress
+          task.downloaded = res.bytesWritten
+          task.total = res.contentLength
+          task.speed = `${speed}/s`
+          
+          this.updateTask(task)
+        },
+        progressInterval: 500,
+      })
+
+      task.jobId = downloadResult.jobId
+      const result = await downloadResult.promise
+      
+      if (result.statusCode === 200) {
+        task.status = 'completed'
+        task.filePath = filePath
+        task.progress = 100
+        this.updateTask(task)
+      } else {
+        throw new Error(`下载失败，状态码: ${result.statusCode}`)
+      }
+    } catch (error: any) {
+      task.status = 'error'
+      task.error = error.message || '未知错误'
+      this.updateTask(task)
+    } finally {
+      this.activeDownloads--
+      this.eventEmitter.emit('taskCompleted', task)
+      
+      // 处理下一个任务
+      this.processNextTask()
+    }
+  }
+
+  // 确保下载目录存在
+  private async ensureDownloadDirectoryExists(downloadDir: string) {
+    try {
+      const dirExists = await existsFile(downloadDir)
+      if (!dirExists) {
+        await mkdir(downloadDir)
+      }
+    } catch (error) {
+      console.warn('创建下载目录失败:', error)
+      // 如果创建Music目录失败，尝试创建到根目录
+      try {
+        const rootDir = privateStorageDirectoryPath
+        const rootDirExists = await existsFile(rootDir)
+        if (!rootDirExists) {
+          await mkdir(rootDir)
+        }
+      } catch (err) {
+        console.error('无法创建下载目录:', err)
+        throw err
+      }
+    }
+  }
+
+  // 生成文件名
+  private generateFileName(musicInfo: LX.Music.MusicInfoOnline): string {
+    // 使用歌名-歌手作为文件名，并清理特殊字符
+    const cleanName = musicInfo.name.replace(/[<>:"/\\|?*]/g, '_')
+    const cleanSinger = musicInfo.singer.replace(/[<>:"/\\|?*]/g, '_')
+    return `${cleanName}-${cleanSinger}.mp3`.substring(0, 200) // 限制文件名长度
+  }
+
+  // 格式化字节大小
+  private formatBytes(bytes: number): string {
+    if (bytes === 0) return '0 Bytes'
+    const k = 1024
+    const sizes = ['Bytes', 'KB', 'MB', 'GB']
+    const i = Math.floor(Math.log(bytes) / Math.log(k))
+    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i]
+  }
+
+  // 暂停下载任务
+  pauseTask(taskId: string) {
+    const task = this.tasks.get(taskId)
+    if (task && task.status === 'downloading' && task.jobId !== undefined) {
+      stopDownload(task.jobId)
+      task.status = 'paused'
+      this.updateTask(task)
+    }
+  }
+
+  // 恢复下载任务
+  resumeTask(taskId: string) {
+    const task = this.tasks.get(taskId)
+    if (task && task.status === 'paused') {
+      task.status = 'waiting' // 设置为等待状态，等待处理
+      this.updateTask(task)
+      
+      // 如果有空闲的下载槽位，立即开始下载
+      if (this.activeDownloads < this.maxConcurrentDownloads) {
+        this.startDownload(task)
+      }
+    }
+  }
+
+  // 删除下载任务
+  removeTask(taskId: string) {
+    const task = this.tasks.get(taskId)
+    if (task) {
+      if (task.status === 'downloading' && task.jobId !== undefined) {
+        stopDownload(task.jobId)
+      }
+      this.tasks.delete(taskId)
+      this.eventEmitter.emit('taskRemoved', taskId)
+    }
+  }
+
+  // 获取所有任务
+  getAllTasks(): DownloadTask[] {
+    return Array.from(this.tasks.values())
+  }
+
+  // 获取特定任务
+  getTask(taskId: string): DownloadTask | undefined {
+    return this.tasks.get(taskId)
+  }
+
+  // 更新任务状态
+  private updateTask(task: DownloadTask) {
+    this.tasks.set(task.id, { ...task })
+    this.eventEmitter.emit('taskUpdated', task)
+    
+    // 更新下载列表UI
+    app_event.downloadListUpdate()
+  }
+
+  // 监听任务更新
+  onTaskUpdated(callback: (task: DownloadTask) => void) {
+    this.eventEmitter.on('taskUpdated', callback)
+  }
+
+  offTaskUpdated(callback: (task: DownloadTask) => void) {
+    this.eventEmitter.off('taskUpdated', callback)
+  }
+
+  // 监听任务完成
+  onTaskCompleted(callback: (task: DownloadTask) => void) {
+    this.eventEmitter.on('taskCompleted', callback)
+  }
+
+  offTaskCompleted(callback: (task: DownloadTask) => void) {
+    this.eventEmitter.off('taskCompleted', callback)
+  }
+}
+
+// 创建下载管理器实例
+export const downloadManager = new DownloadManager()
+
+// 添加歌曲到下载列表的便捷函数
+export const addMusicToDownloadList = async (musicInfo: LX.Music.MusicInfoOnline) => {
+  await downloadManager.addDownloadTask(musicInfo)
+}
+
+// 获取下载列表
+export const getDownloadList = (): LX.Download.ListItem[] => {
+  return downloadManager.getAllTasks().map(task => {
+    return {
+      id: task.id,
+      isComplate: task.status === 'completed',
+      status: task.status as LX.Download.DownloadTaskStatus,
+      statusText: task.error || getStatusText(task.status),
+      downloaded: task.downloaded,
+      total: task.total,
+      progress: task.progress,
+      speed: task.speed,
+      metadata: {
+        musicInfo: task.musicInfo,
+        url: '', // 实际下载完成后可能会更新
+        quality: '128k' as LX.Quality,
+        ext: 'mp3' as LX.Download.FileExt,
+        fileName: downloadManager['generateFileName'](task.musicInfo),
+        filePath: task.filePath || '',
+      },
+    }
+  })
+}
+
+// 获取状态文本
+const getStatusText = (status: DownloadTaskStatus): string => {
+  const statusMap: Record<DownloadTaskStatus, string> = {
+    waiting: '等待中',
+    downloading: '下载中',
+    paused: '已暂停',
+    completed: '已完成',
+    error: '下载失败',
+  }
+  return statusMap[status] || status
+}
+
+// 暂停下载任务
+export const pauseDownloadTask = (taskId: string) => {
+  downloadManager.pauseTask(taskId)
+}
+
+// 恢复下载任务
+export const resumeDownloadTask = (taskId: string) => {
+  downloadManager.resumeTask(taskId)
+}
+
+// 删除下载任务
+export const removeDownloadTask = (taskId: string) => {
+  downloadManager.removeTask(taskId)
+}
