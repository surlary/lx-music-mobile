+import { View, Text, TouchableOpacity, StyleSheet } from 'react-native'
+import { useI18n } from '@/lang'
+import { useTheme } from '@/theme'
+
+interface Props {
+  item: LX.Download.ListItem
+  onLongPress: (item: LX.Download.ListItem) => void
+  onPress: (item: LX.Download.ListItem) => void
+}
+
+export default ({ item, onLongPress, onPress }: Props) => {
+  const theme = useTheme()
+  const t = useI18n()
+
+  const getStatusText = (status: LX.Download.DownloadTaskStatus) => {
+    switch (status) {
+      case 'waiting':
+        return t('download_waiting')
+      case 'run':
+        return t('download_running')
+      case 'pause':
+        return t('download_paused')
+      case 'error':
+        return t('download_error')
+      case 'completed':
+        return t('download_completed')
+      default:
+        return status
+    }
+  }
+
+  const getDisplayInfo = () => {
+    if (item.status === 'completed') {
+      return t('download_completed')
+    } else if (item.status === 'error') {
+      return item.statusText
+    } else {
+      return `${item.metadata.musicInfo.singer} • ${item.progress}% • ${item.speed}`
+    }
+  }
+
+  return (
+    <TouchableOpacity
+      style={[styles.container, { backgroundColor: theme['list-item_background-color'] }]}
+      onPress={() => onPress(item)}
+      onLongPress={() => onLongPress(item)}
+    >
+      <View style={styles.leftContainer}>
+        <Text
+          style={[styles.title, { color: theme['list-item_font-color'] }]}
+          numberOfLines={1}
+        >
+          {item.metadata.musicInfo.name}
+        </Text>
+        <Text
+          style={[styles.info, { color: theme['list-item-subtitle_font-color'] }]}
+          numberOfLines={1}
+        >
+          {getDisplayInfo()}
+        </Text>
+      </View>
+      <View style={styles.rightContainer}>
+        <Text style={[styles.status, { color: theme['list-item-subtitle_font-color'] }]}>
+          {getStatusText(item.status)}
+        </Text>
+      </View>
+    </TouchableOpacity>
+  )
+}
+
+const styles = StyleSheet.create({
+  container: {
+    flexDirection: 'row',
+    alignItems: 'center',
+    paddingHorizontal: 15,
+    paddingVertical: 10,
+    minHeight: 54,
+  },
+  leftContainer: {
+    flex: 1,
+    marginRight: 10,
+    justifyContent: 'center',
+  },
+  rightContainer: {
+    justifyContent: 'center',
+    alignItems: 'flex-end',
+  },
+  title: {
+    fontSize: 15,
+    fontWeight: 'normal',
+  },
+  info: {
+    fontSize: 12,
+    marginTop: 3,
+  },
+  status: {
+    fontSize: 12,
+  },
+})
