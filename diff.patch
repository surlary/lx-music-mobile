+import { privateStorageDirectoryPath, externalStorageDirectoryPath, existsFile, mkdir } from '@/utils/fs'
+import { getData, saveData } from '@/plugins/storage'
+
+// 默认下载路径键
+const DOWNLOAD_PATH_KEY = 'download_path'
+
+/**
+ * 获取当前下载路径
+ * 如果用户没有设置自定义路径，则返回默认的沙盒路径
+ */
+export const getDownloadPath = async (): Promise<string> => {
+  try {
+    // 尝试从存储中获取用户设置的下载路径
+    const customPath = await getData<string>(DOWNLOAD_PATH_KEY)
+    
+    if (customPath && typeof customPath === 'string') {
+      // 检查自定义路径是否存在，如果不存在则尝试创建
+      const pathExists = await existsFile(customPath)
+      if (pathExists) {
+        return customPath
+      } else {
+        // 如果自定义路径不存在，尝试创建
+        try {
+          await mkdir(customPath)
+          return customPath
+        } catch (error) {
+          console.warn('自定义下载路径不可用，使用默认路径:', error)
+        }
+      }
+    }
+  } catch (error) {
+    console.warn('获取下载路径失败，使用默认路径:', error)
+  }
+
+  // 返回默认的沙盒路径
+  const defaultPath = `${privateStorageDirectoryPath}/Music`
+  return defaultPath
+}
+
+/**
+ * 设置下载路径
+ */
+export const setDownloadPath = async (path: string): Promise<void> => {
+  // 验证路径是否可写
+  try {
+    const pathExists = await existsFile(path)
+    if (!pathExists) {
+      await mkdir(path)
+    }
+    
+    // 保存到存储
+    await saveData(DOWNLOAD_PATH_KEY, path)
+  } catch (error) {
+    console.error('设置下载路径失败:', error)
+    throw error
+  }
+}
+
+/**
+ * 重置为默认下载路径
+ */
+export const resetToDefaultDownloadPath = async (): Promise<void> => {
+  await saveData(DOWNLOAD_PATH_KEY, null)
+}
