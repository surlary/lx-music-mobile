+import { useEffect, useState } from 'react'
+import { LIST_IDS } from '@/config/constant'
+import downloadState from './state'
+import { initDownloadList } from './action'
+
+declare const app_event: import('@/event/appEvent').AppEventTypes
+
+export const useDownloadList = () => {
+  const [list, setList] = useState<LX.Download.ListItem[]>(downloadState.list)
+  const [isRefreshing, setIsRefreshing] = useState(downloadState.isRefreshing)
+
+  useEffect(() => {
+    const handleUpdate = () => {
+      setList([...downloadState.list])
+      setIsRefreshing(downloadState.isRefreshing)
+    }
+
+    // 初始化下载列表
+    void initDownloadList()
+
+    // 监听下载列表更新事件
+    app_event.on('downloadListUpdate', handleUpdate)
+
+    return () => {
+      app_event.off('downloadListUpdate', handleUpdate)
+    }
+  }, [])
+
+  return {
+    list,
+    isRefreshing,
+  }
+}
