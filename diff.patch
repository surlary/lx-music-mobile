+import { View, Text, TouchableOpacity, StyleSheet, Alert } from 'react-native'
+import { useI18n } from '@/lang'
+import { useTheme } from '@/theme'
+import { getDownloadPath, setDownloadPath, resetToDefaultDownloadPath } from '@/utils/downloadPath'
+import { existsFile, selectManagedFolder } from '@/utils/fs'
+import { useEffect, useState } from 'react'
+
+export default () => {
+  const theme = useTheme()
+  const t = useI18n()
+  const [currentPath, setCurrentPath] = useState<string>('')
+
+  useEffect(() => {
+    const loadPath = async () => {
+      const path = await getDownloadPath()
+      setCurrentPath(path)
+    }
+    loadPath()
+  }, [])
+
+  const handleSelectCustomPath = async () => {
+    try {
+      // 在Android上请求用户选择一个目录
+      const selectedPath = await selectManagedFolder(true)
+      if (selectedPath) {
+        await setDownloadPath(selectedPath)
+        setCurrentPath(selectedPath)
+        Alert.alert(t('setting_toast'), t('download_path_updated'))
+      }
+    } catch (error: any) {
+      console.error('选择下载路径失败:', error)
+      Alert.alert(t('setting_toast'), t('download_path_update_failed') + error.message)
+    }
+  }
+
+  const handleResetToDefault = async () => {
+    try {
+      await resetToDefaultDownloadPath()
+      const defaultPath = await getDownloadPath()
+      setCurrentPath(defaultPath)
+      Alert.alert(t('setting_toast'), t('download_path_reset_success'))
+    } catch (error: any) {
+      console.error('重置下载路径失败:', error)
+      Alert.alert(t('setting_toast'), t('download_path_reset_failed') + error.message)
+    }
+  }
+
+  return (
+    <View style={[styles.container, { backgroundColor: theme['main-background-color'] }]}>
+      <View style={styles.settingItem}>
+        <Text style={[styles.label, { color: theme['main-font-color'] }]}>
+          {t('download_current_path')}
+        </Text>
+        <Text style={[styles.value, { color: theme['main-subtitle_font-color'] }]} numberOfLines={2}>
+          {currentPath}
+        </Text>
+      </View>
+
+      <TouchableOpacity style={styles.button} onPress={handleSelectCustomPath}>
+        <Text style={styles.buttonText}>{t('download_select_custom_path')}</Text>
+      </TouchableOpacity>
+
+      <TouchableOpacity style={[styles.button, styles.resetButton]} onPress={handleResetToDefault}>
+        <Text style={[styles.buttonText, styles.resetButtonText]}>{t('download_reset_to_default')}</Text>
+      </TouchableOpacity>
+    </View>
+  )
+}
+
+const styles = StyleSheet.create({
+  container: {
+    flex: 1,
+    padding: 15,
+  },
+  settingItem: {
+    marginBottom: 20,
+  },
+  label: {
+    fontSize: 16,
+    marginBottom: 5,
+  },
+  value: {
+    fontSize: 14,
+    lineHeight: 20,
+  },
+  button: {
+    backgroundColor: '#007AFF',
+    padding: 15,
+    borderRadius: 8,
+    alignItems: 'center',
+    marginBottom: 10,
+  },
+  buttonText: {
+    color: 'white',
