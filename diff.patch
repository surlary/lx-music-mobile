+import downloadState from './state'
+import { LIST_IDS } from '@/config/constant'
+import { getDownloadList } from '@/core/download'
+
+export const setDownloadList = (list: LX.Download.ListItem[]) => {
+  downloadState.list = list
+}
+
+export const refreshDownloadList = async() => {
+  downloadState.isRefreshing = true
+  try {
+    const list = getDownloadList()
+    setDownloadList(list)
+  } finally {
+    downloadState.isRefreshing = false
+  }
+}
+
+// 初始化下载列表
+export const initDownloadList = async() => {
+  const list = getDownloadList()
+  setDownloadList(list)
+}
