+}
+
+export default ({ onItemPress, onItemLongPress }: Props) => {
+  const theme = useTheme()
+  const t = useI18n()
+  const { list } = useDownloadList()
+
+  const renderItem = ({ item }: { item: LX.Download.ListItem }) => (
+    <ListItem
+      item={item}
+      onPress={onItemPress}
+      onLongPress={onItemLongPress}
+    />
+  )
+
