+    return (
+      <View style={[styles.emptyContainer, { backgroundColor: theme['main-background-color'] }]}>
+        <Text style={{ color: theme['main-subtitle_font-color'] }}>
+          {t('download_list_empty')}
+        </Text>
+      </View>
+    )
+  }
+
+  return (
+    <FlatList
+      data={list}
+      renderItem={renderItem}
+      keyExtractor={item => item.id}
+      contentContainerStyle={{ backgroundColor: theme['main-background-color'] }}
+      showsVerticalScrollIndicator={false}
+    />
+  )
+}
+
+const styles = StyleSheet.create({
+  emptyContainer: {
+    flex: 1,
+    justifyContent: 'center',
+    alignItems: 'center',
